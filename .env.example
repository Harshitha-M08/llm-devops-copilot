# DevOps Platform - Environment Variables Template
# Copy this file to .env and update with your actual values
# WARNING: Never commit .env files with real credentials to version control

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
NODE_ENV=development

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=devops_db
POSTGRES_USER=devops
POSTGRES_PASSWORD=devops123
DATABASE_URL=postgresql://devops:devops123@postgres:5432/devops_db

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0
REDIS_URL=redis://:redis123@redis:6379/0

# =============================================================================
# RABBITMQ MESSAGE BROKER
# =============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=devops
RABBITMQ_PASSWORD=devops123
RABBITMQ_VHOST=devops
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://devops:devops123@rabbitmq:5672/devops

# =============================================================================
# QDRANT VECTOR DATABASE (Cloud)
# =============================================================================
# Get your Qdrant Cloud credentials at https://cloud.qdrant.io
QDRANT_HOST=https://your-cluster-id.region.provider.cloud.qdrant.io
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_COLLECTION_NAME=embeddings
QDRANT_VECTOR_SIZE=1536

# =============================================================================
# LLM SERVICE (Python FastAPI)
# =============================================================================
LLM_SERVICE_HOST=llm-service
LLM_SERVICE_PORT=8000
LLM_SERVICE_URL=http://llm-service:8000
LLM_LOG_LEVEL=info

# OpenAI Configuration
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=60

# LLM Provider Selection (for agents)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo

# Anthropic Configuration (Optional)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=2000

# =============================================================================
# SLACK INTEGRATION (for Notifier Agent)
# =============================================================================
# Create Slack App at https://api.slack.com/apps
# Required scopes: chat:write, chat:write.public
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL=#devopsalerts
SLACK_USERNAME=Agent X
SLACK_ICON_EMOJI=:robot_face:

# =============================================================================
# APPROVAL BACKEND (Node.js/Express)
# =============================================================================
APPROVAL_BACKEND_HOST=approval-backend
APPROVAL_BACKEND_PORT=3000
APPROVAL_BACKEND_URL=http://approval-backend:3000
BACKEND_LOG_LEVEL=info

# JWT Authentication
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# =============================================================================
# MONITORING - PROMETHEUS & GRAFANA
# =============================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# =============================================================================
# AGENT-SPECIFIC CONFIGURATION
# =============================================================================

# Monitoring Agent
MONITORING_LOG_LEVEL=INFO
MONITORING_CPU_THRESHOLD=80.0
MONITORING_MEMORY_THRESHOLD=85.0
MONITORING_ERROR_RATE_THRESHOLD=5.0
MONITORING_POD_RESTART_THRESHOLD=3

# Analyzer Agent
ANALYZER_LOG_LEVEL=INFO
ANALYZER_RAG_ENABLED=true
ANALYZER_RAG_TOP_K=5

# Auto-Response Agent
AUTORESPONSE_LOG_LEVEL=INFO
AUTORESPONSE_DRY_RUN=false
AUTORESPONSE_AUTO_EXECUTE_THRESHOLD=95
AUTORESPONSE_MAX_SCALE_REPLICAS=10

# Notifier Agent
NOTIFIER_LOG_LEVEL=INFO
NOTIFIER_NOTIFY_INCIDENTS=true
NOTIFIER_NOTIFY_ANALYSIS=true
NOTIFIER_NOTIFY_ACTIONS=true
NOTIFIER_NOTIFY_APPROVALS=true
NOTIFIER_NOTIFY_SEVERITY_LEVELS=["medium","high","critical"]

# =============================================================================
# KUBERNETES CONFIGURATION (Optional)
# =============================================================================
K8S_NAMESPACE=devops

# =============================================================================
# LOGGING & DEBUGGING
# =============================================================================
LOG_LEVEL=info
DEBUG=false
