# Application Settings
APP_NAME=worker-service
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=devops_exchange
RABBITMQ_RECONNECT_DELAY=5

# Queue Names
QUEUE_LLM_REQUESTS=llm_requests
QUEUE_APPROVALS=approvals
QUEUE_NOTIFICATIONS=notifications
QUEUE_DEAD_LETTER=dead_letter

# Worker Settings
WORKER_PREFETCH_COUNT=10
MAX_RETRIES=3
RETRY_DELAY=5

# PostgreSQL Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=devops_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# LLM Service Configuration
LLM_SERVICE_URL=http://localhost:8000
LLM_SERVICE_TIMEOUT=300
LLM_SERVICE_MAX_RETRIES=3

# Email/SMTP Configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=DevOps System
SMTP_USE_TLS=true

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=
SLACK_ENABLED=false

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
