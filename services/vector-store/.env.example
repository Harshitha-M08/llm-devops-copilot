# Qdrant Vector Store Configuration
# Copy this file to .env and update with your actual values

# ==========================================
# Qdrant Connection Settings
# ==========================================

# For self-hosted Qdrant (local Docker deployment)
QDRANT_URL=http://localhost:6333
QDRANT_GRPC_URL=http://localhost:6334

# For Qdrant Cloud (https://cloud.qdrant.io/)
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_CLOUD_CLUSTER_URL=https://your-cluster.qdrant.io:6333

# ==========================================
# Authentication
# ==========================================

# API Key for authentication (optional for local, required for cloud)
# Generate a secure key: openssl rand -hex 32
QDRANT_API_KEY=

# Read-only API key (optional, for restricted access)
QDRANT_READ_ONLY_API_KEY=

# ==========================================
# Service Configuration
# ==========================================

# Log level: DEBUG, INFO, WARN, ERROR
QDRANT_LOG_LEVEL=INFO

# Disable telemetry (set to true to disable)
QDRANT_TELEMETRY_DISABLED=false

# Request timeout in seconds
QDRANT_TIMEOUT=60

# ==========================================
# Collection Settings
# ==========================================

# Default vector dimensions (depends on embedding model)
# OpenAI text-embedding-ada-002: 1536
# OpenAI text-embedding-3-small: 1536
# OpenAI text-embedding-3-large: 3072
# Cohere embed-english-v3.0: 1024
VECTOR_DIMENSION=1536

# Distance metric: cosine, euclidean, dot
DISTANCE_METRIC=cosine

# ==========================================
# Performance Settings
# ==========================================

# Maximum number of search results
MAX_SEARCH_RESULTS=100

# Batch size for bulk operations
BATCH_SIZE=100

# Connection pool size
CONNECTION_POOL_SIZE=10

# ==========================================
# Backup Configuration
# ==========================================

# Backup interval in seconds (86400 = 24 hours)
BACKUP_INTERVAL=86400

# Backup retention in days
BACKUP_RETENTION_DAYS=7

# Backup storage path
BACKUP_PATH=./backups

# ==========================================
# Resource Limits (for Docker deployment)
# ==========================================

# CPU limit (e.g., 2.0 = 2 cores)
QDRANT_CPU_LIMIT=2.0

# Memory limit (e.g., 4G = 4 gigabytes)
QDRANT_MEMORY_LIMIT=4G

# ==========================================
# Advanced Settings
# ==========================================

# Enable on-disk storage for large collections
QDRANT_ON_DISK_STORAGE=false

# HNSW index parameters
HNSW_M=16
HNSW_EF_CONSTRUCT=100

# Indexing threshold (number of points before indexing)
INDEXING_THRESHOLD=20000

# ==========================================
# TLS/SSL Configuration (for production)
# ==========================================

# Enable TLS
QDRANT_TLS_ENABLED=false

# Path to TLS certificate
# QDRANT_TLS_CERT=/path/to/cert.pem

# Path to TLS private key
# QDRANT_TLS_KEY=/path/to/key.pem

# ==========================================
# Monitoring & Observability
# ==========================================

# Enable Prometheus metrics endpoint
QDRANT_METRICS_ENABLED=true

# Metrics port
QDRANT_METRICS_PORT=9091

# Health check endpoint
QDRANT_HEALTH_CHECK_PATH=/healthz

# ==========================================
# Development Settings
# ==========================================

# Enable debug mode
DEBUG=false

# Enable verbose logging
VERBOSE=false

# Recreate collections on startup (WARNING: deletes existing data)
RECREATE_COLLECTIONS=false
