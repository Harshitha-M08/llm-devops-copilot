# LLM Service Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# LLM Provider Configuration
# ============================================

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp

# Preferred Provider (openai or gemini)
PREFERRED_PROVIDER=openai

# LLM Parameters
MAX_TOKENS=2000
TEMPERATURE=0.7

# ============================================
# Vector Store Configuration (Qdrant)
# ============================================

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key-here
COLLECTION_NAME=knowledge_base
EMBEDDING_DIM=1536

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5

# ============================================
# Message Queue Configuration (RabbitMQ)
# ============================================

RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE=llm_tasks

# ============================================
# Database Configuration (PostgreSQL)
# ============================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=llm_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-here

# ============================================
# Cache Configuration (Redis)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# ============================================
# Service Configuration
# ============================================

# Server Settings
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO

# CORS Settings (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# ============================================
# Monitoring & Observability
# ============================================

# Prometheus Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# Logging
LOG_FORMAT=json
LOG_FILE=/var/log/llm-service.log

# ============================================
# Security
# ============================================

# API Authentication
API_KEY=your-api-key-here
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Feature Flags
# ============================================

ENABLE_STREAMING=true
ENABLE_RAG=true
ENABLE_TASK_QUEUE=true
ENABLE_CACHING=true

# ============================================
# Development/Testing
# ============================================

# Environment
ENVIRONMENT=development
DEBUG=false

# Testing
TEST_MODE=false
MOCK_PROVIDERS=false
